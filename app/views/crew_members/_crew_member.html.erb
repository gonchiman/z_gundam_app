<div id="<%= dom_id crew_member %>">
  <div>
    <strong>Image:</strong>
    <% if crew_member.image.attached? %>
      <%= image_tag crew_member.image, width: 160 %>
    <% else %>
      No image
    <% end %>
  </div>

  <div>
    <strong>Captain warship image:</strong>
    <% if crew_member.captain_warship_image.attached? %>
      <%= image_tag crew_member.captain_warship_image, width: 320 %>
    <% else %>
      No captain warship image
    <% end %>
  </div>

  <div>
    <strong>Name:</strong>
    <%= crew_member.name %>
  </div>

  <div>
    <strong>Gender:</strong>
    <%= crew_member.gender %>
  </div>

  <div>
    <strong>Rank:</strong>
    <%= crew_member.rank %>
  </div>

  <div>
    <strong>Role type:</strong>
    <%= crew_member.role_type %>
  </div>
  
  <div>
    <strong>explanation:</strong>
    <%= crew_member.explanation %>
  </div>

</div>
