<p style="color: green"><%= notice %></p>

<h1>Mobile suit information</h1>

<section class="profile-detail">
  <div class="profile-detail-media">
    <% if @mobile_suit.image.attached? %>
      <%= image_tag @mobile_suit.image %>
    <% else %>
      <span>No mobile suit image</span>
    <% end %>
  </div>

  <div class="profile-detail-content">
    <div class="profile-detail-heading">
      <span>Mobile suit</span>
      <h2><%= @mobile_suit.name %></h2>
    </div>

    <div class="profile-detail-meta-grid">
      <div class="profile-detail-meta-item">
        <span>Purchase cost</span>
        <strong>
          <% if @mobile_suit.purchase_cost.present? %>
            <%= number_to_currency(@mobile_suit.purchase_cost, unit: "$", precision: 0) %>
          <% else %>
            Not set
          <% end %>
        </strong>
      </div>
    </div>

    <div class="profile-detail-description">
      <h2>Explanation</h2>

      <% if @mobile_suit.explanation.present? %>
        <%= simple_format(@mobile_suit.explanation) %>
      <% else %>
        <p>No explanation</p>
      <% end %>
    </div>
  </div>
</section>

<div class="page-actions">
  <%= link_to "Edit this mobile suit", edit_mobile_suit_path(@mobile_suit) %>
  <%= link_to "Back to mobile suits", mobile_suits_path %>

  <%= button_to "Destroy this mobile suit", @mobile_suit, method: :delete %>
</div>
