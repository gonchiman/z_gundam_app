<% if warship.errors.any? %>
  <div style="color: red">
    <h2><%= pluralize(warship.errors.count, "error") %> prohibited this warship from being saved:</h2>

    <ul>
      <% warship.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: warship) do |form| %>
  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <% if warship.new_record? %>
    <% captains = CrewMember.where(role_type: ["captain_only", "captain_and_pilot"]).order(:name) %>

    <h2>Captain</h2>

    <div class="selection-card-grid">
      <label class="selection-card">
        <div class="selection-card-image">
          <span>No captain</span>
        </div>

        <div class="selection-card-body">
          <%= form.radio_button :captain_id, "", checked: warship.captain_id.blank? %>
          <h2>No captain</h2>
          <p>Rank: -</p>
          <p>Cost: <%= number_to_currency(0, unit: "$", precision: 0) %></p>
        </div>
      </label>

      <% captains.each do |captain| %>
        <label class="selection-card">
          <div class="selection-card-image">
            <% if captain.image.attached? %>
              <%= image_tag captain.image %>
            <% else %>
              <span>No image</span>
            <% end %>
          </div>

          <div class="selection-card-body">
            <%= form.radio_button :captain_id, captain.id %>
            <h2><%= captain.name %></h2>
            <p>Rank: <%= captain.rank.presence || "-" %></p>
            <p>Cost: <%= number_to_currency(captain.hire_cost, unit: "$", precision: 0) %></p>
          </div>
        </label>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.submit %>
  </div>
<% end %>

<% unless warship.new_record? %>
  <% pilot_crew_member_ids = warship.pilot_assignments.select(:crew_member_id) %>
  <% captains = CrewMember.where(role_type: ["captain_only", "captain_and_pilot"]).where.not(id: pilot_crew_member_ids).order(:name) %>

  <h2>Captain</h2>

  <div class="selection-card-grid">
    <div class="selection-card">
      <div class="selection-card-image">
        <%= button_to warship_path(warship),
          method: :patch,
          params: { warship: { captain_id: "" } },
          class: "selection-card-image-button" do %>
          <span>No captain</span>
        <% end %>
      </div>

      <div class="selection-card-body">
        <h2>No captain</h2>
        <p>Rank: -</p>
        <p>Cost: <%= number_to_currency(0, unit: "$", precision: 0) %></p>
        <% if warship.captain.blank? %>
          <p>Selected</p>
        <% end %>
      </div>
    </div>

    <% captains.each do |captain| %>
      <div class="selection-card">
        <div class="selection-card-image">
          <%= button_to warship_path(warship),
            method: :patch,
            params: { warship: { captain_id: captain.id } },
            class: "selection-card-image-button" do %>
            <% if captain.image.attached? %>
              <%= image_tag captain.image %>
            <% else %>
              <span>No image</span>
            <% end %>
          <% end %>
        </div>

        <div class="selection-card-body">
          <h2><%= captain.name %></h2>
          <p>Rank: <%= captain.rank.presence || "-" %></p>
          <p>Cost: <%= number_to_currency(captain.hire_cost, unit: "$", precision: 0) %></p>
          <% if warship.captain_id == captain.id %>
            <p>Selected</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
