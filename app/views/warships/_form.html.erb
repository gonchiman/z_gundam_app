<%= form_with(model: warship) do |form| %>
  <% if warship.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(warship.errors.count, "error") %> prohibited this warship from being saved:</h2>

      <ul>
        <% warship.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :captain_id, style: "display: block" %>
    <%= form.collection_select :captain_id,
      CrewMember.where(role_type: ["captain_only", "captain_and_pilot"]),
      :id,
      :name,
      include_blank: true
    %>
  </div>

  <div>
    <%= form.label :image, style: "display: block" %>
    <%= form.file_field :image %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
