<p style="color: green"><%= notice %></p>

<h1>Warships</h1>

<div class="warship-card-grid">
  <% @warships.each do |warship| %>
    <% passenger_count = warship.pilot_assignments.count + (warship.captain.present? ? 1 : 0) %>
    <% warship_image = warship.display_image %>

    <article class="warship-card">
      <%= link_to warship, class: "warship-card-main-image" do %>
        <% if warship_image.present? %>
          <%= image_tag warship_image %>
        <% else %>
          <span>No image</span>
        <% end %>
      <% end %>

      <div class="warship-card-body">
        <h2><%= link_to warship.name, warship %></h2>

        <div class="warship-card-captain">
          <div class="warship-card-captain-image">
            <% if warship.captain.present? && warship.captain.image.attached? %>
              <%= image_tag warship.captain.image %>
            <% else %>
              <span>No captain image</span>
            <% end %>
          </div>

          <div>
            <span>Captain</span>
            <strong><%= warship.captain&.name || "No captain" %></strong>
          </div>
        </div>

        <div class="warship-card-meta">
          <div>
            <span>Passengers</span>
            <strong><%= passenger_count %></strong>
          </div>

          <div>
            <span>Created by</span>
            <strong><%= warship.user&.name || "Unknown" %></strong>
          </div>
        </div>
      </div>
    </article>
  <% end %>
</div>

<p>
  <%= link_to "New warship", new_warship_path %>
</p>
