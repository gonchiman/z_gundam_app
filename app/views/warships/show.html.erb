<p style="color: green"><%= notice %></p>
<p style="color: red"><%= alert %></p>

<h1><%= @warship.name %></h1>

<h2>Captain</h2>

<table>
  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Gender</th>
      <th>Rank</th>
    </tr>
  </thead>

  <tbody>
    <% if @warship.captain.present? %>
      <tr>
        <td>
          <% if @warship.captain.image.attached? %>
            <%= link_to @warship.captain do %>
              <%= image_tag @warship.captain.image, width: 100 %>
            <% end %>
          <% else %>
            No image
          <% end %>
        </td>
        <td><%= @warship.captain.name %></td>
        <td><%= @warship.captain.gender %></td>
        <td><%= @warship.captain.rank %></td>
      </tr>
    <% else %>
      <tr>
        <td colspan="4">No captain</td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Purchased mobile suits</h2>

<table>
  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Delete</th>
    </tr>
  </thead>

  <tbody>
    <% if @warship.warship_mobile_suits.any? %>
      <% @warship.warship_mobile_suits.each do |warship_mobile_suit| %>
        <tr>
          <td>
            <% if warship_mobile_suit.mobile_suit.image.attached? %>
              <%= link_to warship_mobile_suit.mobile_suit do %>
                <%= image_tag warship_mobile_suit.mobile_suit.image, width: 100 %>
              <% end %>
            <% else %>
              No image
            <% end %>
          </td>
          <td><%= warship_mobile_suit.mobile_suit.name %></td>
          <td>
            <%= button_to "Delete", warship_mobile_suit_path(warship_mobile_suit), method: :delete %>
          </td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td colspan="3">No mobile suits purchased</td>
      </tr>
    <% end %>
  </tbody>
</table>

<h3>Buy mobile suit</h3>

<% available_mobile_suits = MobileSuit.where.not(id: @warship.mobile_suit_ids) %>
<% if available_mobile_suits.any? %>
  <%= form_with(model: WarshipMobileSuit.new) do |form| %>
    <%= form.hidden_field :warship_id, value: @warship.id %>
    <%= form.collection_select :mobile_suit_id, available_mobile_suits, :id, :name %>
    <%= form.submit "Buy mobile suit" %>
  <% end %>
<% else %>
  <p>All mobile suits have already been purchased.</p>
<% end %>

<h2>Hired pilots</h2>

<table>
  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Gender</th>
      <th>Rank</th>
      <th>Mobile suit</th>
      <th>Assign</th>
      <th>Delete</th>
    </tr>
  </thead>

  <tbody>
    <% if @warship.pilot_assignments.any? %>
      <% @warship.pilot_assignments.each do |pilot_assignment| %>
        <tr>
          <td>
            <% if pilot_assignment.crew_member.image.attached? %>
              <%= link_to pilot_assignment.crew_member do %>
                <%= image_tag pilot_assignment.crew_member.image, width: 100 %>
              <% end %>
            <% else %>
              No image
            <% end %>
          </td>
          <td><%= pilot_assignment.crew_member.name %></td>
          <td><%= pilot_assignment.crew_member.gender %></td>
          <td><%= pilot_assignment.crew_member.rank %></td>
          <td>
            <% if pilot_assignment.mobile_suit.present? && pilot_assignment.mobile_suit.image.attached? %>
              <%= image_tag pilot_assignment.mobile_suit.image, width: 100 %>
            <% elsif pilot_assignment.mobile_suit.present? %>
              <%= pilot_assignment.mobile_suit.name %>
            <% else %>
              Not assigned
            <% end %>
          </td>
          <td><%= link_to "Assign", edit_pilot_assignment_path(pilot_assignment) %></td>
          <td>
            <%= button_to "Delete", pilot_assignment_path(pilot_assignment), method: :delete %>
          </td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td colspan="7">No pilots hired</td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Hire pilot", new_pilot_assignment_path(warship_id: @warship.id) %>

<div>
  <%= link_to "Edit this warship", edit_warship_path(@warship) %> |
  <%= link_to "Back to warships", warships_path %>

  <%= button_to "Destroy this warship", @warship, method: :delete %>
</div>