<p style="color: green"><%= notice %></p>
<p style="color: red"><%= alert %></p>

<h1><%= @warship.name %></h1>

<% if @warship.main_image.attached? %>
  <div>
    <%= image_tag @warship.main_image, width: 600 %>
  </div>
<% else %>
  <p>No main image</p>
<% end %>

<h2>Total combat power</h2>
<p><%= @warship.total_combat_power %></p>

<h2>Captain</h2>

<table>
  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Gender</th>
      <th>Rank</th>
    </tr>
  </thead>

  <tbody>
    <% if @warship.captain.present? %>
      <tr>
        <td>
          <% if @warship.captain.image.attached? %>
            <%= link_to @warship.captain do %>
              <%= image_tag @warship.captain.image, width: 100 %>
            <% end %>
          <% else %>
            No image
          <% end %>
        </td>
        <td><%= @warship.captain.name %></td>
        <td><%= @warship.captain.gender %></td>
        <td><%= @warship.captain.rank %></td>
      </tr>
    <% else %>
      <tr>
        <td colspan="4">No captain</td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Pilots</h2>

<% if @warship.pilot_assignments.any? %>
  <div class="selection-card-grid">
    <% @warship.pilot_assignments.each do |pilot_assignment| %>
      <div class="selection-card">
        <div class="pilot-assignment-images">
          <div class="selection-card-image">
            <% if pilot_assignment.crew_member.image.attached? %>
              <%= link_to pilot_assignment.crew_member do %>
                <%= image_tag pilot_assignment.crew_member.image %>
              <% end %>
            <% else %>
              <span>No pilot image</span>
            <% end %>
          </div>

          <div class="selection-card-image">
            <% if pilot_assignment.mobile_suit.present? && pilot_assignment.mobile_suit.image.attached? %>
              <%= link_to edit_pilot_assignment_path(pilot_assignment) do %>
                <%= image_tag pilot_assignment.mobile_suit.image %>
              <% end %>
            <% elsif pilot_assignment.mobile_suit.present? %>
              <%= link_to pilot_assignment.mobile_suit.name, edit_pilot_assignment_path(pilot_assignment) %>
            <% else %>
              <%= link_to "Not assigned", edit_pilot_assignment_path(pilot_assignment) %>
            <% end %>
          </div>
        </div>

        <div class="selection-card-body">
          <p>Total power: <%= pilot_assignment.combat_power %></p>
          <%= button_to "Delete", pilot_assignment_path(pilot_assignment), method: :delete %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No pilots hired</p>
<% end %>

<%= link_to "Hire pilot", new_pilot_assignment_path(warship_id: @warship.id) %>

<h2>Mobile suits</h2>

<table>
  <thead>
    <tr>
      <th>Image</th>
      <th>Name</th>
      <th>Quantity</th>
      <th>Assigned</th>
      <th>Decrease</th>
    </tr>
  </thead>

  <tbody>
    <% if @warship.warship_mobile_suits.any? %>
      <% @warship.warship_mobile_suits.each do |warship_mobile_suit| %>
        <tr>
          <td>
            <% if warship_mobile_suit.mobile_suit.image.attached? %>
              <%= link_to warship_mobile_suit.mobile_suit do %>
                <%= image_tag warship_mobile_suit.mobile_suit.image, width: 100 %>
              <% end %>
            <% else %>
              No image
            <% end %>
          </td>
          <td><%= warship_mobile_suit.mobile_suit.name %></td>
          <td><%= warship_mobile_suit.quantity %></td>
          <td><%= @warship.pilot_assignments.where(mobile_suit_id: warship_mobile_suit.mobile_suit_id).count %></td>
          <td>
            <%= button_to "Decrease", warship_mobile_suit_path(warship_mobile_suit), method: :delete %>
          </td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td colspan="5">No mobile suits purchased</td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Buy mobile suit", new_warship_mobile_suit_path(warship_id: @warship.id) %>

<h2>Budget</h2>
<table>
  <tbody>
    <tr>
      <th>Budget</th>
      <td><%= number_to_currency(@warship.budget, unit: "$", precision: 0) %></td>
    </tr>
    <tr>
      <th>Captain cost</th>
      <td><%= number_to_currency(@warship.captain_cost, unit: "$", precision: 0) %></td>
    </tr>
    <tr>
      <th>Pilot cost</th>
      <td><%= number_to_currency(@warship.pilot_cost, unit: "$", precision: 0) %></td>
    </tr>
    <tr>
      <th>Mobile suit cost</th>
      <td><%= number_to_currency(@warship.mobile_suit_cost, unit: "$", precision: 0) %></td>
    </tr>
    <tr>
      <th>Total cost</th>
      <td><%= number_to_currency(@warship.total_cost, unit: "$", precision: 0) %></td>
    </tr>
    <tr>
      <th>Remaining budget</th>
      <td><%= number_to_currency(@warship.remaining_budget, unit: "$", precision: 0) %></td>
    </tr>
  </tbody>
</table>

<div>
  <%= link_to "Edit this warship", edit_warship_path(@warship) %> |
  <%= link_to "Back to warships", warships_path %>

  <%= button_to "Destroy this warship", @warship, method: :delete %>
</div>