<% content_for :head do %>
  <%= stylesheet_link_tag "home", "data-turbo-track": "reload" %>
<% end %>

<% home_gallery_captain_names = ["ブライト・ノア", "ヘンケン・ベッケナー", "パプテマス・シロッコ"] %>
<% home_gallery_captains_by_name = CrewMember.where(name: home_gallery_captain_names).index_by(&:name) %>
<% home_gallery_captains = home_gallery_captain_names.map { |name| home_gallery_captains_by_name[name] } %>

<% sample_captain = home_gallery_captains.compact.first %>
<% sample_warship_image = sample_captain&.captain_warship_image %>

<% sample_pilot_names = ["カミーユ・ビダン", "クワトロ・バジーナ", "アムロ・レイ"] %>
<% sample_pilots_by_name = CrewMember.where(name: sample_pilot_names).index_by(&:name) %>
<% sample_pilot = sample_pilot_names.map { |name| sample_pilots_by_name[name] }.compact.first %>

<% sample_mobile_suit_names = ["Zガンダム", "ガンダムMk-II", "百式"] %>
<% sample_mobile_suits_by_name = MobileSuit.where(name: sample_mobile_suit_names).index_by(&:name) %>
<% sample_mobile_suit = sample_mobile_suit_names.map { |name| sample_mobile_suits_by_name[name] }.compact.first %>

<div class="home-page">
  <section class="home-hero">
    <div class="home-hero-text">
      <h1>自分だけの戦艦を編成しよう</h1>

      <div class="home-hero-actions">
        <%= link_to "View Warships", warships_path, class: "home-primary-button" %>
        <%= link_to "Create Warship", new_warship_path, class: "home-secondary-button" %>
      </div>
    </div>

    <div class="home-warship-gallery">
      <% home_gallery_captains.each do |captain| %>
        <article class="home-warship-gallery-card">
          <div class="home-warship-gallery-image">
            <% if captain&.captain_warship_image&.attached? %>
              <%= image_tag captain.captain_warship_image %>
            <% else %>
              <span>戦艦</span>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <section class="home-section home-overview-section">
    <div class="home-section-heading">
      <h2>アプリの概要</h2>
      <span>戦艦を中心に、艦長・パイロット・モビルスーツを組み合わせます。</span>
    </div>

    <div class="home-overview-board">
      <div class="home-overview-main-card">
        <div class="home-overview-main-image">
          <% if sample_warship_image&.attached? %>
            <%= image_tag sample_warship_image %>
          <% else %>
            <span>戦艦</span>
          <% end %>
        </div>

        <div class="home-overview-main-body">
          <h3>戦艦</h3>
          <p>
            戦艦が編成の中心です。艦長を登録し、搭乗する人員と機体を整えていきます。
          </p>
        </div>
      </div>

      <div class="home-overview-parts">
        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_captain&.image&.attached? %>
              <%= image_tag sample_captain.image %>
            <% else %>
              <span>艦長</span>
            <% end %>
          </div>
          <div>
            <h3>艦長</h3>
            <p>戦艦の指揮を担当する人物を登録します。</p>
          </div>
        </div>

        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_pilot&.image&.attached? %>
              <%= image_tag sample_pilot.image %>
            <% else %>
              <span>パイロット</span>
            <% end %>
          </div>
          <div>
            <h3>パイロット</h3>
            <p>戦艦に所属するパイロットを雇います。</p>
          </div>
        </div>

        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_mobile_suit&.image&.attached? %>
              <%= image_tag sample_mobile_suit.image %>
            <% else %>
              <span>機体</span>
            <% end %>
          </div>
          <div>
            <h3>モビルスーツ</h3>
            <p>必要な機体を購入し、パイロットに割り当てます。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section-heading">
      <h2>アプリの使い方</h2>
      <span>戦艦詳細ページで、次の流れに沿って編成を完成させます。</span>
    </div>

    <div class="home-step-grid">
      <article class="home-step-card">
        <div class="home-step-number">1</div>
        <div class="home-step-image">
          <% if sample_captain&.image&.attached? %>
            <%= image_tag sample_captain.image %>
          <% else %>
            <span>艦長</span>
          <% end %>
        </div>
        <h3>艦長を登録</h3>
        <p>戦艦の指揮を担当する艦長を登録します。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">2</div>
        <div class="home-step-image">
          <% if sample_pilot&.image&.attached? %>
            <%= image_tag sample_pilot.image %>
          <% else %>
            <span>パイロット</span>
          <% end %>
        </div>
        <h3>パイロットを雇う</h3>
        <p>必要な人員を雇い、戦艦の搭乗者を整えます。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">3</div>
        <div class="home-step-image">
          <% if sample_mobile_suit&.image&.attached? %>
            <%= image_tag sample_mobile_suit.image %>
          <% else %>
            <span>モビルスーツ</span>
          <% end %>
        </div>
        <h3>機体を購入</h3>
        <p>モビルスーツを購入し、戦艦の編成を完成させます。</p>
      </article>
    </div>

    <div class="home-bottom-action">
      <%= link_to "Start Building", warships_path, class: "home-primary-button" %>
    </div>
  </section>
</div>
