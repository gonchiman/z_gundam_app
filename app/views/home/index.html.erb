<% featured_warships = Warship.limit(3).to_a %>
<% sample_warship = Warship.find_by(id: 3) || featured_warships.first %>
<% sample_pilot_assignment = sample_warship&.pilot_assignments&.first %>
<% sample_captain = sample_warship&.captain %>
<% sample_pilot = sample_pilot_assignment&.crew_member %>
<% sample_mobile_suit = sample_pilot_assignment&.mobile_suit || sample_warship&.warship_mobile_suits&.first&.mobile_suit %>

<div class="home-page">
  <section class="home-hero">
    <div class="home-hero-text">
      <p class="home-eyebrow">Z Fleet Manager</p>
      <h1>自分だけの戦艦を編成しよう</h1>
      <p>
        艦長を登録し、パイロットを雇い、モビルスーツを購入して、
        自分だけの戦艦構成を作るアプリです。
      </p>

      <div class="home-hero-actions">
        <%= link_to "戦艦一覧を見る", warships_path, class: "home-primary-button" %>
        <%= link_to "新しい戦艦を作る", new_warship_path, class: "home-secondary-button" %>
      </div>
    </div>

    <div class="home-hero-visual">
      <div class="home-warship-collage">
        <% if featured_warships.any? %>
          <% featured_warships.each do |warship| %>
            <% warship_image = warship.display_image %>

            <%= link_to warship, class: "home-warship-collage-card" do %>
              <div class="home-warship-collage-image">
                <% if warship_image.present? %>
                  <%= image_tag warship_image %>
                <% else %>
                  <span>画像なし</span>
                <% end %>
              </div>
              <strong><%= warship.name %></strong>
            <% end %>
          <% end %>
        <% else %>
          <%= link_to new_warship_path, class: "home-warship-collage-card home-warship-collage-card-empty" do %>
            <div class="home-warship-collage-image">
              <span>戦艦を作成</span>
            </div>
            <strong>最初の戦艦を作る</strong>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section-heading">
      <p>Build</p>
      <h2>戦艦を作る</h2>
      <span>画像つきのカードから戦艦を選び、詳細ページで編成を進めます。</span>
    </div>

    <div class="home-build-grid">
      <% if featured_warships.any? %>
        <% featured_warships.each do |warship| %>
          <% warship_image = warship.display_image %>

          <%= link_to warship, class: "home-build-card" do %>
            <div class="home-build-card-image">
              <% if warship_image.present? %>
                <%= image_tag warship_image %>
              <% else %>
                <span>画像なし</span>
              <% end %>
            </div>

            <div class="home-build-card-body">
              <h3><%= warship.name %></h3>
              <p>この戦艦をベースに、艦長・パイロット・モビルスーツを編成します。</p>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <div class="home-empty-card">
          <h3>戦艦がまだありません</h3>
          <p>まずは戦艦を作成してください。</p>
          <%= link_to "戦艦を作る", new_warship_path, class: "home-primary-button" %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="home-section home-overview-section">
    <div class="home-section-heading">
      <p>Overview</p>
      <h2>アプリの概要</h2>
      <span>戦艦を中心に、艦長・パイロット・モビルスーツを組み合わせます。</span>
    </div>

    <div class="home-overview-board">
      <div class="home-overview-main-card">
        <div class="home-overview-main-image">
          <% if sample_warship&.display_image.present? %>
            <%= image_tag sample_warship.display_image %>
          <% else %>
            <span>戦艦</span>
          <% end %>
        </div>

        <div class="home-overview-main-body">
          <h3><%= sample_warship&.name || "戦艦" %></h3>
          <p>
            戦艦が編成の中心です。艦長を登録し、搭乗する人員と機体を整えていきます。
          </p>
        </div>
      </div>

      <div class="home-overview-parts">
        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_captain&.image&.attached? %>
              <%= image_tag sample_captain.image %>
            <% else %>
              <span>艦長</span>
            <% end %>
          </div>
          <div>
            <h3>艦長</h3>
            <p>戦艦の指揮を担当する人物を登録します。</p>
          </div>
        </div>

        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_pilot&.image&.attached? %>
              <%= image_tag sample_pilot.image %>
            <% else %>
              <span>パイロット</span>
            <% end %>
          </div>
          <div>
            <h3>パイロット</h3>
            <p>戦艦に所属するパイロットを雇います。</p>
          </div>
        </div>

        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_mobile_suit&.image&.attached? %>
              <%= image_tag sample_mobile_suit.image %>
            <% else %>
              <span>機体</span>
            <% end %>
          </div>
          <div>
            <h3>モビルスーツ</h3>
            <p>必要な機体を購入し、パイロットに割り当てます。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section-heading">
      <p>How to use</p>
      <h2>アプリの使い方</h2>
      <span>戦艦詳細ページで、次の流れに沿って編成を完成させます。</span>
    </div>

    <div class="home-step-grid">
      <article class="home-step-card">
        <div class="home-step-number">1</div>
        <div class="home-step-image">
          <% if sample_warship&.display_image.present? %>
            <%= image_tag sample_warship.display_image %>
          <% else %>
            <span>戦艦</span>
          <% end %>
        </div>
        <h3>戦艦を選ぶ</h3>
        <p>戦艦一覧から、編成したい戦艦を選びます。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">2</div>
        <div class="home-step-image">
          <% if sample_captain&.image&.attached? %>
            <%= image_tag sample_captain.image %>
          <% else %>
            <span>艦長</span>
          <% end %>
        </div>
        <h3>艦長を登録</h3>
        <p>戦艦の指揮を担当する艦長を登録します。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">3</div>
        <div class="home-step-image">
          <% if sample_pilot&.image&.attached? %>
            <%= image_tag sample_pilot.image %>
          <% else %>
            <span>パイロット</span>
          <% end %>
        </div>
        <h3>パイロットを雇う</h3>
        <p>必要な人員を雇い、戦艦の搭乗者を整えます。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">4</div>
        <div class="home-step-image">
          <% if sample_mobile_suit&.image&.attached? %>
            <%= image_tag sample_mobile_suit.image %>
          <% else %>
            <span>モビルスーツ</span>
          <% end %>
        </div>
        <h3>機体を購入</h3>
        <p>モビルスーツを購入し、戦艦の編成を完成させます。</p>
      </article>
    </div>

    <div class="home-bottom-action">
      <%= link_to "戦艦編成を始める", warships_path, class: "home-primary-button" %>
    </div>
  </section>
</div>

<style>
  .home-page {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .home-hero,
  .home-section {
    border: 1px solid #d1d5db;
    border-radius: 14px;
    background: #ffffff;
    box-shadow: 0 10px 24px rgba(31, 41, 55, 0.08);
  }

  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 1fr);
    gap: 28px;
    align-items: center;
    padding: 28px;
    overflow: hidden;
    background:
      radial-gradient(circle at top right, rgba(185, 28, 28, 0.18), transparent 34%),
      linear-gradient(135deg, #ffffff, #f9fafb);
  }

  .home-hero-text h1 {
    margin: 0 0 14px;
    color: #111827;
    font-size: 40px;
    line-height: 1.2;
  }

  .home-hero-text p {
    margin: 0;
    color: #374151;
    line-height: 1.8;
  }

  .home-eyebrow,
  .home-section-heading p {
    margin: 0 0 8px;
    color: #b91c1c;
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 0.06em;
  }

  .home-hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 22px;
  }

  .home-primary-button,
  .home-secondary-button {
    display: inline-block;
    border-radius: 8px;
    padding: 10px 14px;
    font-weight: bold;
    text-decoration: none;
  }

  .home-primary-button {
    background-color: #b91c1c;
    color: #ffffff;
  }

  .home-primary-button:hover {
    background-color: #991b1b;
  }

  .home-secondary-button {
    border: 1px solid #d1d5db;
    background-color: #ffffff;
    color: #1f2937;
  }

  .home-secondary-button:hover {
    background-color: #f3f4f6;
  }

  .home-warship-collage {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    width: 100%;
  }

  .home-warship-collage-card,
  .home-build-card {
    display: block;
    overflow: hidden;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    background-color: #ffffff;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 6px 16px rgba(31, 41, 55, 0.08);
  }

  .home-warship-collage-card:hover,
  .home-build-card:hover {
    transform: translateY(-2px);
  }

  .home-warship-collage-image {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 190px;
    background-color: #e5e7eb;
    color: #6b7280;
  }

  .home-warship-collage-image img,
  .home-build-card-image img,
  .home-overview-main-image img,
  .home-overview-part-image img,
  .home-step-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-warship-collage-card strong {
    display: block;
    padding: 10px;
    text-align: center;
  }

  .home-warship-collage-card-empty {
    grid-column: 1 / -1;
  }

  .home-section {
    padding: 24px;
  }

  .home-section-heading {
    margin-bottom: 18px;
  }

  .home-section-heading h2 {
    margin: 0 0 8px;
    color: #111827;
    font-size: 28px;
  }

  .home-section-heading span {
    color: #4b5563;
    line-height: 1.7;
  }

  .home-build-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .home-build-card-image {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 210px;
    background-color: #e5e7eb;
    color: #6b7280;
  }

  .home-build-card-body {
    padding: 14px;
  }

  .home-build-card-body h3,
  .home-overview-main-body h3,
  .home-overview-part-card h3,
  .home-step-card h3,
  .home-empty-card h3 {
    margin: 0 0 8px;
    color: #111827;
  }

  .home-build-card-body p,
  .home-overview-main-body p,
  .home-overview-part-card p,
  .home-step-card p,
  .home-empty-card p {
    margin: 0;
    color: #4b5563;
    line-height: 1.7;
  }

  .home-empty-card {
    grid-column: 1 / -1;
    border: 1px dashed #d1d5db;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    background-color: #f9fafb;
  }

  .home-empty-card .home-primary-button {
    margin-top: 14px;
  }

  .home-overview-board {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.1fr);
    gap: 18px;
    align-items: stretch;
  }

  .home-overview-main-card,
  .home-overview-part-card,
  .home-step-card {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    background-color: #ffffff;
  }

  .home-overview-main-card {
    overflow: hidden;
  }

  .home-overview-main-image {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 260px;
    background-color: #e5e7eb;
    color: #6b7280;
  }

  .home-overview-main-body {
    padding: 16px;
  }

  .home-overview-parts {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .home-overview-part-card {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 14px;
    align-items: center;
    padding: 12px;
  }

  .home-overview-part-image {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 110px;
    height: 110px;
    overflow: hidden;
    border-radius: 10px;
    background-color: #e5e7eb;
    color: #6b7280;
    text-align: center;
  }

  .home-step-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .home-step-card {
    position: relative;
    padding: 14px;
  }

  .home-step-number {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: #b91c1c;
    color: #ffffff;
    font-weight: bold;
    line-height: 32px;
    text-align: center;
  }

  .home-step-image {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 160px;
    margin-bottom: 14px;
    overflow: hidden;
    border-radius: 10px;
    background-color: #e5e7eb;
    color: #6b7280;
    text-align: center;
  }

  .home-bottom-action {
    margin-top: 20px;
    text-align: center;
  }

  @media (max-width: 900px) {
    .home-hero,
    .home-overview-board {
      grid-template-columns: 1fr;
    }

    .home-warship-collage,
    .home-build-grid,
    .home-step-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .home-hero {
      padding: 20px;
    }

    .home-hero-text h1 {
      font-size: 30px;
    }

    .home-warship-collage,
    .home-build-grid,
    .home-step-grid {
      grid-template-columns: 1fr;
    }

    .home-overview-part-card {
      grid-template-columns: 1fr;
    }

    .home-overview-part-image {
      width: 100%;
      height: 180px;
    }
  }
</style>
