<% featured_warships = Warship.limit(3).to_a %>
<% sample_warship = Warship.find_by(id: 3) || featured_warships.first %>
<% sample_pilot_assignment = sample_warship&.pilot_assignments&.first %>
<% sample_captain = sample_warship&.captain %>
<% sample_pilot = sample_pilot_assignment&.crew_member %>
<% sample_mobile_suit = sample_pilot_assignment&.mobile_suit || sample_warship&.warship_mobile_suits&.first&.mobile_suit %>

<div class="home-page">
  <section class="home-hero">
    <div class="home-hero-text">
      <p class="home-eyebrow">Z Fleet Manager</p>
      <h1>自分だけの戦艦を編成しよう</h1>
      <p>
        艦長を登録し、パイロットを雇い、モビルスーツを購入して、
        自分だけの戦艦構成を作るアプリです。
        複数の戦艦を作成し、編成の違いを楽しめます。
      </p>

      <div class="home-hero-actions">
        <%= link_to "View Warships", warships_path, class: "home-primary-button" %>
        <%= link_to "Create Warship", new_warship_path, class: "home-secondary-button" %>
      </div>
    </div>

    <div class="home-warship-gallery">
      <% if featured_warships.any? %>
        <% featured_warships.each do |warship| %>
          <% warship_image = warship.display_image %>

          <article class="home-warship-gallery-card">
            <div class="home-warship-gallery-image">
              <% if warship_image.present? %>
                <%= image_tag warship_image %>
              <% else %>
                <span>画像なし</span>
              <% end %>
            </div>
            <strong><%= warship.name %></strong>
          </article>
        <% end %>
      <% else %>
        <article class="home-warship-gallery-card">
          <div class="home-warship-gallery-image">
            <span>戦艦</span>
          </div>
          <strong>戦艦を作成できます</strong>
        </article>
      <% end %>
    </div>
  </section>

  <section class="home-section home-overview-section">
    <div class="home-section-heading">
      <p>概要</p>
      <h2>アプリの概要</h2>
      <span>戦艦を中心に、艦長・パイロット・モビルスーツを組み合わせます。</span>
    </div>

    <div class="home-overview-board">
      <div class="home-overview-main-card">
        <div class="home-overview-main-image">
          <% if sample_warship&.display_image.present? %>
            <%= image_tag sample_warship.display_image %>
          <% else %>
            <span>戦艦</span>
          <% end %>
        </div>

        <div class="home-overview-main-body">
          <h3>戦艦</h3>
          <p>
            戦艦が編成の中心です。艦長を登録し、搭乗する人員と機体を整えていきます。
          </p>
        </div>
      </div>

      <div class="home-overview-parts">
        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_captain&.image&.attached? %>
              <%= image_tag sample_captain.image %>
            <% else %>
              <span>艦長</span>
            <% end %>
          </div>
          <div>
            <h3>艦長</h3>
            <p>戦艦の指揮を担当する人物を登録します。</p>
          </div>
        </div>

        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_pilot&.image&.attached? %>
              <%= image_tag sample_pilot.image %>
            <% else %>
              <span>パイロット</span>
            <% end %>
          </div>
          <div>
            <h3>パイロット</h3>
            <p>戦艦に所属するパイロットを雇います。</p>
          </div>
        </div>

        <div class="home-overview-part-card">
          <div class="home-overview-part-image">
            <% if sample_mobile_suit&.image&.attached? %>
              <%= image_tag sample_mobile_suit.image %>
            <% else %>
              <span>機体</span>
            <% end %>
          </div>
          <div>
            <h3>モビルスーツ</h3>
            <p>必要な機体を購入し、パイロットに割り当てます。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-section-heading">
      <p>手順</p>
      <h2>アプリの使い方</h2>
      <span>戦艦詳細ページで、次の流れに沿って編成を完成させます。</span>
    </div>

    <div class="home-step-grid">
      <article class="home-step-card">
        <div class="home-step-number">1</div>
        <div class="home-step-image">
          <% if sample_warship&.display_image.present? %>
            <%= image_tag sample_warship.display_image %>
          <% else %>
            <span>戦艦</span>
          <% end %>
        </div>
        <h3>戦艦を選ぶ</h3>
        <p>戦艦一覧から、編成したい戦艦を選びます。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">2</div>
        <div class="home-step-image">
          <% if sample_captain&.image&.attached? %>
            <%= image_tag sample_captain.image %>
          <% else %>
            <span>艦長</span>
          <% end %>
        </div>
        <h3>艦長を登録</h3>
        <p>戦艦の指揮を担当する艦長を登録します。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">3</div>
        <div class="home-step-image">
          <% if sample_pilot&.image&.attached? %>
            <%= image_tag sample_pilot.image %>
          <% else %>
            <span>パイロット</span>
          <% end %>
        </div>
        <h3>パイロットを雇う</h3>
        <p>必要な人員を雇い、戦艦の搭乗者を整えます。</p>
      </article>

      <article class="home-step-card">
        <div class="home-step-number">4</div>
        <div class="home-step-image">
          <% if sample_mobile_suit&.image&.attached? %>
            <%= image_tag sample_mobile_suit.image %>
          <% else %>
            <span>モビルスーツ</span>
          <% end %>
        </div>
        <h3>機体を購入</h3>
        <p>モビルスーツを購入し、戦艦の編成を完成させます。</p>
      </article>
    </div>

    <div class="home-bottom-action">
      <%= link_to "戦艦編成を始める", warships_path, class: "home-primary-button" %>
    </div>
  </section>
</div>

<style>
  .home-page {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .home-hero,
  .home-section {
    border: 1px solid #d1d5db;
    border-radius: 10px;
    background-color: #ffffff;
  }

  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 1fr);
    gap: 24px;
    align-items: center;
    padding: 24px;
  }

  .home-hero-text h1 {
    margin: 0 0 12px;
    color: #111827;
    font-size: 32px;
    line-height: 1.3;
  }

  .home-hero-text p {
    margin: 0;
    color: #374151;
    line-height: 1.8;
  }

  .home-eyebrow,
  .home-section-heading p {
    margin: 0 0 8px;
    color: #b91c1c;
    font-size: 13px;
    font-weight: bold;
  }

  .home-hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .home-primary-button,
  .home-secondary-button {
    display: inline-block;
    border-radius: 6px;
    padding: 9px 12px;
    font-weight: bold;
    text-decoration: none;
  }

  .home-primary-button {
    background-color: #b91c1c;
    color: #ffffff;
  }

  .home-primary-button:hover {
    background-color: #991b1b;
  }

  .home-secondary-button {
    border: 1px solid #d1d5db;
    background-color: #ffffff;
    color: #1f2937;
  }

  .home-secondary-button:hover {
    background-color: #f3f4f6;
  }

  .home-warship-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .home-warship-gallery-card {
    overflow: hidden;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background-color: #ffffff;
  }

  .home-warship-gallery-image,
  .home-overview-main-image,
  .home-overview-part-image,
  .home-step-image {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #e5e7eb;
    color: #6b7280;
    text-align: center;
  }

  .home-warship-gallery-image {
    height: 160px;
  }

  .home-warship-gallery-image img,
  .home-overview-main-image img,
  .home-overview-part-image img,
  .home-step-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-warship-gallery-card strong {
    display: block;
    padding: 10px;
    text-align: center;
  }

  .home-section {
    padding: 22px;
  }

  .home-section-heading {
    margin-bottom: 16px;
  }

  .home-section-heading h2 {
    margin: 0 0 8px;
    color: #111827;
    font-size: 26px;
  }

  .home-section-heading span {
    color: #4b5563;
    line-height: 1.7;
  }

  .home-overview-board {
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.1fr);
    gap: 16px;
  }

  .home-overview-main-card,
  .home-overview-part-card,
  .home-step-card {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background-color: #ffffff;
  }

  .home-overview-main-card {
    overflow: hidden;
  }

  .home-overview-main-image {
    height: 240px;
  }

  .home-overview-main-body {
    padding: 14px;
  }

  .home-overview-parts {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .home-overview-part-card {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 12px;
    align-items: center;
    padding: 12px;
  }

  .home-overview-part-image {
    width: 100px;
    height: 100px;
    overflow: hidden;
    border-radius: 8px;
  }

  .home-overview-main-body h3,
  .home-overview-part-card h3,
  .home-step-card h3 {
    margin: 0 0 8px;
    color: #111827;
  }

  .home-overview-main-body p,
  .home-overview-part-card p,
  .home-step-card p {
    margin: 0;
    color: #4b5563;
    line-height: 1.7;
  }

  .home-step-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .home-step-card {
    position: relative;
    padding: 12px;
  }

  .home-step-number {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background-color: #b91c1c;
    color: #ffffff;
    font-weight: bold;
    line-height: 30px;
    text-align: center;
  }

  .home-step-image {
    height: 150px;
    margin-bottom: 12px;
    overflow: hidden;
    border-radius: 8px;
  }

  .home-bottom-action {
    margin-top: 18px;
    text-align: center;
  }

  @media (max-width: 900px) {
    .home-hero,
    .home-overview-board {
      grid-template-columns: 1fr;
    }

    .home-warship-gallery,
    .home-step-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .home-hero {
      padding: 18px;
    }

    .home-hero-text h1 {
      font-size: 28px;
    }

    .home-warship-gallery,
    .home-step-grid {
      grid-template-columns: 1fr;
    }

    .home-overview-part-card {
      grid-template-columns: 1fr;
    }

    .home-overview-part-image {
      width: 100%;
      height: 160px;
    }
  }
</style>
